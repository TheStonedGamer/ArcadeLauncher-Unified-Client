{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArcadeLauncher",
  "version": "0.1.0",
  "identifier": "com.thestonedgamer.arcadelauncher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ArcadeLauncher",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEMkZFRTNBQ0EwNzEwOEEKUldTS0VBZktPdTR2alVPWlArYjQxZ2IzZXJJS2pNc3RiNkpacW11ZFVFQXJQR29FMGlYb2N1RFkK",
      "endpoints": [
        "https://github.com/TheStonedGamer/ArcadeLauncher-Unified-Client/releases/latest/download/latest.json"
      ]
    }
  }
}
