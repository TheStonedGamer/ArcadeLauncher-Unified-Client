{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArcadeLauncher",
  "version": "0.13.24",
  "identifier": "com.thestonedgamer.arcadelauncher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ArcadeLauncher",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "deb", "rpm", "appimage"],
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/updater"],
    "category": "Games",
    "shortDescription": "ArcadeLauncher game library",
    "longDescription": "ArcadeLauncher is a Steam-style game library and launcher with friends, chat, and per-user admin-free updates.",
    "homepage": "https://github.com/TheStonedGamer/ArcadeLauncher-Unified-Client",
    "publisher": "TheStonedGamer",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "nsis/installer-hooks.nsh"
      },
      "wix": {
        "template": "wix/main.wxs"
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libayatana-appindicator-gtk3"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERDQ0IyRDc1MkEzRUI2QkYKUldTL3RqNHFkUzNMM09jS24za1h1YTlxYklTblVjQ1hYdUR0ZnZ1b2x5dWREbzBydGpVYnNEQzkK",
      "endpoints": [
        "https://github.com/TheStonedGamer/ArcadeLauncher-Unified-Client/releases/latest/download/latest.json"
      ]
    }
  }
}
