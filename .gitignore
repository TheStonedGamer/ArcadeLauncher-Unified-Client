# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Expo (mobile companion) build artefacts. The lockfile is NOT ignored — the
# Android CI leg runs `npm ci` and needs it committed. android/ and ios/ are
# regenerated by `expo prebuild` on every build, so they stay out.
mobile/.expo/
mobile/android/
mobile/ios/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Updater signing keys — NEVER commit. Private key lives outside the repo
# (~/.tauri) and goes into CI secrets only.
*.key
*.key.pub
arcade-updater.key*

# Local secrets — runner VM credentials, never commit
.secrets/

# In-project agent memory (local-only, never committed)
memory/

LOOP_PROMPT.md

# Stray regenerated handoff at the repo root; the real one is docs/HANDOFF.md
/HANDOFF.md
