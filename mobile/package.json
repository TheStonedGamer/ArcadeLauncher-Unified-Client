    "expo-clipboard": "~7.0.0",
    "expo-document-picker": "~13.0.1",
    "expo-file-system": "~18.0.6",
    "expo-image-picker": "~16.0.3",
    "expo-notifications": "~0.29.11",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-webrtc": "^124.0.4"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
