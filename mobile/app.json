{
  "expo": {
    "name": "ArcadeLauncher",
    "slug": "arcadelauncher-companion",
    "version": "0.14.1",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "arcadelauncher",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0e0f13"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "net.orlandoaio.arcadelauncher.companion"
    },
    "android": {
      "package": "net.orlandoaio.arcadelauncher.companion",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#0e0f13"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "@config-plugins/react-native-webrtc",
      "./plugins/withReleaseSigning",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 34
          }
        }
      ],
      "expo-asset"
    ]
  }
}
